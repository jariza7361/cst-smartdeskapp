  "CstSmartDeskApiD23CAE10": {
   "Type": "AWS::Lambda::Function",
   "Properties": {
    "Code": {
     "ZipFile": "\n        exports.handler = async (event) => {\n          const path = event.path || event.rawPath;\n          \n          if (path === '/api/fetch') {\n            return {\n              statusCode: 200,\n              headers: { 'Content-Type': 'application/json' },\n              body: JSON.stringify({ ok: true, message: 'API fetch endpoint working' })\n            };\n          }\n          \n          if (path === '/api/copilot') {\n            return {\n              statusCode: 200,\n              headers: { 'Content-Type': 'application/json' },\n              body: JSON.stringify({ response: 'Copilot API working', timestamp: new Date().toISOString() })\n            };\n          }\n          \n          return {\n            statusCode: 404,\n            headers: { 'Content-Type': 'application/json' },\n            body: JSON.stringify({ error: 'Not found' })\n          };\n        };\n      "
    },
    "Handler": "index.handler",
    "Role": {
     "Fn::GetAtt": [
      "CstSmartDeskApiServiceRoleABF349AF",
      "Arn"
     ]
    },
    "Runtime": "nodejs20.x"
   },
   "DependsOn": [
    "CstSmartDeskApiServiceRoleABF349AF"
   ],
   "Metadata": {
    "aws:cdk:path": "CstSmartDeskStack/CstSmartDeskApi/Resource"
   }
