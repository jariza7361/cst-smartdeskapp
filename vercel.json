{
  "installCommand": "npm ci --omit=dev",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self' https://api.openai.com; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
        },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=(), clipboard-read=(self), clipboard-write=(self)"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/app.js", "destination": "/public/app.js" },
    { "source": "/utils/:path*", "destination": "/public/utils/:path*" }
  ]
}
