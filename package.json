{
  "name": "cst-smartdeskapp",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "prebuild": "node scripts/decode-favicon.mjs",
    "dev": "vite --port 53123",
    "build": "vite build",
    "build:clean-env": "VSCODE_INSPECTOR_OPTIONS= NODE_OPTIONS= vite build",
    "preview": "vite preview --port 53124 --strictPort",
    "preview:clean-env": "VSCODE_INSPECTOR_OPTIONS= NODE_OPTIONS= vite preview --port 53124 --strictPort",
    "preview:alt": "VSCODE_INSPECTOR_OPTIONS= NODE_OPTIONS= vite preview --host --port 53126 --strictPort",
    "lint": "eslint . --max-warnings=50",
    "format": "prettier -w .",
    "format:check": "prettier --check .",
    "validate": "node scripts/pre-commit-check.mjs",
    "precommit": "npm run validate && npm run format:check && npm run lint",
    "prepush": "npm run precommit && npm run test && npm run build",
    "pre-pr": "npm run prepush && npm run e2e",
    "pr-prep": "node scripts/pr-prep.mjs",
    "pr-prep:draft": "node scripts/pr-prep.mjs --draft",
    "pr-prep:quick": "node scripts/pr-prep.mjs --quick",
    "pr-setup": "node scripts/pr-setup.mjs",
    "test": "vitest run",
    "test:clean-env": "VSCODE_INSPECTOR_OPTIONS= NODE_OPTIONS= vitest run",
    "e2e": "playwright test",
    "e2e:ui": "VSCODE_INSPECTOR_OPTIONS= NODE_OPTIONS= npx playwright test --ui",
    "e2e:codex": "scripts/e2e-codex.sh",
    "check:lock": "node scripts/check-lock.mjs",
    "doctor": "node scripts/doctor.mjs",
    "doctor:local": "node doctor.mjs",
    "tesseract:install": "node scripts/install-tesseract-assets.mjs",
    "postinstall": "node scripts/install-tesseract-assets.mjs",
    "verify": "npm run doctor:local && npm run lint && npm test",
    "fix": "node doctor.mjs --write",
    "test:ci": "node tests/decode-favicon.smoke.mjs",
    "start:local": "node server.js",
    "start:local:clean-env": "VSCODE_INSPECTOR_OPTIONS= NODE_OPTIONS= node server.js",
    "auto-dev": "node scripts/auto-dev.mjs",
    "ship": "node scripts/quick-ship.mjs",
    "parity:smoke": "node scripts/parity-smoke.mjs",
    "extract-assets": "node scripts/extract-assets.mjs",
    "aws:deploy": "cd cdk && npm install && npm run deploy",
    "aws:sync": "aws s3 sync dist/ s3://$(aws cloudformation describe-stacks --stack-name CstSmartDeskStack --query 'Stacks[0].Outputs[?OutputKey==`BucketName`].OutputValue' --output text) --delete",
    "aws:invalidate": "aws cloudfront create-invalidation --distribution-id $(aws cloudformation describe-stacks --stack-name CstSmartDeskStack --query 'Stacks[0].Outputs[?OutputKey==`CloudFrontDistributionId`].OutputValue' --output text) --paths '/*'",
    "aws:url": "aws cloudformation describe-stacks --stack-name CstSmartDeskStack --query 'Stacks[0].Outputs[?OutputKey==`CloudFrontUrl`].OutputValue' --output text",
    "structure-check": "node scripts/structure-check.mjs"
  },
  "devDependencies": {
    "@eslint/js": "9.11.1",
    "@playwright/test": "1.46.1",
    "eslint": "^9.34.0",
    "express": "^4.21.2",
    "prettier": "3.3.3",
    "tesseract.js": "2.1.5",
    "tesseract.js-core": "2.2.0",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "uuid": "^11.1.0",
    "vercel": "^41.0.2"
  }
}
